---
import { query, singleton } from "../../.contentrain/client/index.mjs";
import type { Navigation } from "../../.contentrain/client/index.d.ts";
import BaseLayout from "../layouts/BaseLayout.astro";

const site = singleton("site-settings").locale("en").get();
const nav = singleton("navigation").locale("en").get();
type NavItem = NonNullable<Navigation["items"]>[number];
const hero = singleton("hero").locale("en").get();
const statOrder = ["sections", "deploy-time", "shared-models"];
const stats = query("stat-item")
  .locale("en")
  .all()
  .toSorted((left, right) => statOrder.indexOf(left.id) - statOrder.indexOf(right.id));
const featureOrder = ["narrative-landing", "contentrain-first", "deployable-defaults"];
const features = query("feature")
  .locale("en")
  .all()
  .toSorted((left, right) => featureOrder.indexOf(left.id) - featureOrder.indexOf(right.id));
const testimonials = query("testimonial").locale("en").all();
const faqs = query("faq-item").locale("en").all();
---

<BaseLayout title={site.site_name} description={hero.subtitle}>
  <main>
    <header class="site-header">
      <a href="/" class="brand">{site.site_name}</a>
      <div class="header-actions">
        {nav.items?.map((item: NavItem) => <a class="pill" href={item.href}>{item.label}</a>)}
        <a class="button" href={nav.cta_href}>{nav.cta_label}</a>
      </div>
    </header>

    <section class="hero">
      <div class="hero-copy">
        <div class="eyebrow">{hero.eyebrow}</div>
        <h1>{hero.title}</h1>
        <p>{hero.subtitle}</p>
        <div class="header-actions">
          <a class="button" href={hero.primary_cta_href}>{hero.primary_cta_label}</a>
          <a class="pill" href={hero.secondary_cta_href}>{hero.secondary_cta_label}</a>
        </div>
      </div>

      <aside class="hero-card">
        {hero.hero_media ? <img src={hero.hero_media} alt={hero.title} class="hero-media" /> : null}
        <div class="eyebrow">Starter scorecard</div>
        {
          stats.map((stat) => (
            <div class="stat">
              <span>{stat.label}</span>
              <strong>{stat.value}</strong>
            </div>
          ))
        }
      </aside>
    </section>

    <section id="features">
      <h2 class="section-title">A section system designed for launch velocity and editorial growth.</h2>
      <div class="grid-3">
        {
          features.map((feature) => (
            <article class="feature-card">
              <h3>{feature.title}</h3>
              <p>{feature.summary}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="proof">
      <h2 class="section-title">Interfaces that feel shipped, not assembled.</h2>
      <div class="grid-2">
        {
          testimonials.map((item) => (
            <article class="quote-card">
              {item.avatar ? (
                <div class="testimonial-head">
                  <img src={item.avatar} alt={item.person_name ?? "Customer"} class="avatar" />
                  <div>
                    <strong>{item.person_name}</strong>
                    <div style="color: var(--ct-color-muted);">{item.person_role}</div>
                  </div>
                </div>
              ) : null}
              <p style="font-size: 1.1rem; line-height: 1.7;">“{item.quote}”</p>
            </article>
          ))
        }
      </div>
    </section>

    <section id="faq">
      <h2 class="section-title">Built for teams who want structure before scale.</h2>
      <div class="grid-2">
        {
          faqs.map((item) => (
            <article class="faq-card">
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section>
      <h2 class="section-title">See how the starter maps sections, content models, and Contentrain links.</h2>
      <article class="feature-card">
        <h3>Open the blueprint page</h3>
        <p>
          The starter now includes a dedicated internal page that explains the section system,
          content architecture, and official Contentrain surfaces for docs, studio, and SDK usage.
        </p>
        <a class="button" href="/blueprint">Browse blueprint</a>
      </article>
    </section>

    <footer>
      <span>Deploy-ready Astro landing starter</span>
      <span>Shared tokens, native rendering, Contentrain-first modeling</span>
    </footer>
  </main>
</BaseLayout>
