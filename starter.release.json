{
  "display_name": "Contentrain Astro Landing",
  "repository_name": "contentrain-starter-astro-landing",
  "repository_description": "High-polish Astro landing page starter with Contentrain content models and generated SDK client.",
  "repository_topics": ["contentrain", "astro", "starter", "landing-page", "marketing", "typescript"],
  "visibility": "public",
  "template_repository": true,
  "framework": "astro",
  "node_version": "22",
  "package_manager": "pnpm@10.17.0",
  "install_command": "pnpm install",
  "check_command": "pnpm check",
  "build_command": "pnpm build",
  "preview_command": "pnpm preview",
  "deploy_targets": [
    { "provider": "vercel", "output": "dist", "command": "pnpm deploy:vercel" },
    { "provider": "netlify", "output": "dist", "command": "pnpm deploy:netlify" },
    { "provider": "cloudflare-pages", "output": "dist", "command": "pnpm deploy:cloudflare" }
  ]
}
